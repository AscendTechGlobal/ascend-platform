# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: distributed rate limiting for production
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Recommended: public canonical URL used by the frontend
NEXT_PUBLIC_SITE_URL=https://ascendtechglobal.com

# Optional: custom Next.js build output directory
NEXT_DIST_DIR=

# VPS runtime defaults
HOSTNAME=0.0.0.0
PORT=3000
